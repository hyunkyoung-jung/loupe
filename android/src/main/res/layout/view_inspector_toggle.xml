<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_inspector"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="12dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="#FFF5F5F5">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Design Inspector"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#FF1C1C1C" />

                <TextView
                    android:id="@+id/tv_inspector_desc"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="뷰의 컬러·패딩·마진·토큰을 인스펙션합니다"
                    android:textSize="13sp"
                    android:textColor="#FF6B6B6B" />
            </LinearLayout>

            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/switch_inspector"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- 범례 -->
    <LinearLayout
        android:id="@+id/legend_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="8dp"
        android:paddingTop="8dp"
        android:visibility="gone">

        <View
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:background="#FF5F0080" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:text="바운드"
            android:textSize="11sp"
            android:textColor="#FF757575" />

        <View
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:layout_marginStart="14dp"
            android:background="#8000C853" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:text="패딩"
            android:textSize="11sp"
            android:textColor="#FF757575" />

        <View
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:layout_marginStart="14dp"
            android:background="#80FF6D00" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:text="마진"
            android:textSize="11sp"
            android:textColor="#FF757575" />
    </LinearLayout>
</LinearLayout>
